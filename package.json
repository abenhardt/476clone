{
  "name": "camp-burnt-gin-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "a11y": "npm run build && npm run a11y:lighthouse && npm run a11y:axe",
    "a11y:lighthouse": "lighthouse http://localhost:4173 --preset=desktop --output=html --output-path=./lighthouse-report.html --chrome-flags=\"--headless\" --quiet",
    "a11y:axe": "start-server-and-test preview http://localhost:4173 'axe http://localhost:4173 --exit'",
    "a11y:dev": "axe http://localhost:5173",
    "analyze": "npm run build && open dist/stats.html",
    "perf": "npm run build && npm run preview & sleep 3 && npm run a11y:lighthouse"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@reduxjs/toolkit": "^2.11.2",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.35.1",
    "i18next": "^25.8.14",
    "laravel-echo": "^2.3.1",
    "lucide-react": "^0.487.0",
    "pusher-js": "^8.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-qr-code": "^2.0.18",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "chromedriver",
      "esbuild"
    ],
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-r5fr-rjxr-66jc"
      ]
    },
    "overrides": {
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@<=4.17.23": ">=4.18.1",
      "lodash-es@<=4.17.23": ">=4.18.1",
      "basic-ftp@=5.2.0": ">=5.2.1"
    }
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^13.0.3",
    "madge": "^8.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^6.0.11",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": ">=5.2.2"
    }
  }
}
